{
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [
        {
          "type": "host",
          "value": "clienthub.plusplusminus.co.za"
        }
      ],
      "destination": "https://pulse.plusplusminus.co.za/:path",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/sync/reconcile",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/process-email-queue",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/send-digests",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/retry-pushes",
      "schedule": "*/15 * * * *"
    }
  ]
}
