# Supabase Configuration
# Get these values from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Encryption Key
# Generate a random 256-bit (32-byte) base64 key for encrypting stored API tokens
# You can generate one with: openssl rand -base64 32
ENCRYPTION_KEY=your-base64-encryption-key-here

# App URL
# Full URL of your deployment (used for webhooks, email links, etc.)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Resend (email delivery)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
FROM_EMAIL=notifications@yourdomain.com

# Cron job authentication
# Generate a random secret: openssl rand -hex 32
# Must match CRON_SECRET in Vercel project settings
CRON_SECRET=your-cron-secret-here

# PostHog Analytics
# Get these from your PostHog project settings: https://app.posthog.com/settings/project
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
